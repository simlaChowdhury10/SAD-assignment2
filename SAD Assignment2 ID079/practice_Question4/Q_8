import 'dart:io';

void main() {
  List<String> tasks = [];

  while (true) {
    print("\n1.Add Task");
    print("2.Remove Task");
    print("3.View Task");
    print("4.Exit");

    String choice = stdin.readLineSync()!;

    if (choice == "1") {
      print("Enter task:");
      tasks.add(stdin.readLineSync()!);
    }

    else if (choice == "2") {
      print("Enter task index:");
      int index = int.parse(stdin.readLineSync()!);
      tasks.removeAt(index);
    }

    else if (choice == "3") {
      for (int i = 0; i < tasks.length; i++) {
        print("$i : ${tasks[i]}");
      }
    }

    else if (choice == "4") {
      break;
    }
  }
}