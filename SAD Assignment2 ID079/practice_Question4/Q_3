import 'dart:io';

void main() {
  List<double> expenses = [];
  double total = 0;

  for (int i = 1; i <= 3; i++) {
    print("Enter expense $i:");
    double amount = double.parse(stdin.readLineSync()!);
    expenses.add(amount);
  }

  for (double e in expenses) {
    total += e;
  }

  print("Total Expense: $total");
}